{
  "admin": {
    "listen": "localhost:2019"
  },
  "apps": {
    "http": {
      "servers": {
        "addon_https": {
          "listen": [":7701"],
          "routes": [
            {
              "match": [{"host": ["homelab.mara-palermo.ts.net"]}],
              "handle": [
                {
                  "handler": "rewrite",
                  "strip_path_prefix": "/stremio-i18n"
                },
                {
                  "handler": "reverse_proxy",
                  "upstreams": [{"dial": "stremio-i18n:7700"}]
                }
              ],
              "terminal": true
            }
          ],
          "logs": {}
        }
      }
    },
    "tls": {
      "certificates": {
        "load_files": [
          {
            "certificate": "/app/cert.pem",
            "key": "/app/key.pem",
            "tags": ["homelab"]
          }
        ]
      },
      "automation": {
        "on_demand": {}
      }
    }
  }
}
