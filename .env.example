# Backend environment configuration — copy to .env and fill in your values.
# .env is gitignored; never commit real keys.

# ──────────────────────────────────────────────────────────────────────────────
# TMDB (themoviedb.org) — required for localized metadata (titles + descriptions)
# Free signup at https://www.themoviedb.org/settings/api
#
# You need ONE of these two — v4 Bearer token is preferred:
#
#   • TMDB_READ_TOKEN (v4 Read Access Token)
#       Used as `Authorization: Bearer <token>` header.
#       Recommended for production. Scoped to read-only by default.
#
#   • TMDB_API_KEY (v3 API Key)
#       Used as `?api_key=<key>` query string.
#       Older auth method, but still supported.
#
# If both are set, TMDB_READ_TOKEN wins.
# ──────────────────────────────────────────────────────────────────────────────
TMDB_READ_TOKEN=
TMDB_API_KEY=

# Optional: Mixpanel analytics
MIXPANEL_KEY=

# Optional: server port (default 7700)
# PORT=7700

# Optional: catalog refresh interval in ms (default 21600000 = 6h)
# REFRESH_INTERVAL=21600000

# Optional: cache control (default USE_CACHE=true, FORCE_REFRESH=false)
# USE_CACHE=false
# FORCE_REFRESH=true

# Optional: NODE_ENV (production enables stricter error handling)
# NODE_ENV=production